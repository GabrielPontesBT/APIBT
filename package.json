{
  "name": "api-docs",
  "version": "0.0.0",
  "scripts": {
    "build": "ng build --base-href /apibanking/ && node scripts/generate-static-routes.js",
    "serve:local": "npm run build && python -m http.server 8081 --directory dist",
    "build:docs-content": "node scripts/build-docs-content.js",
    "build:docs-content-v4": "node scripts/build-docs-content-v4.js",
    "build:docs-navigation": "node scripts/build-docs-navigation.js",
    "build:docs-search": "node scripts/build-docs-search.js",
    "build:release-assets": "node scripts/build-release-assets.js",
    "validate:docs": "node scripts/validate-docs.js",
    "build:docs": "npm run build:docs-content && npm run build:docs-content-v4 && npm run build:docs-navigation && npm run build:docs-search && npm run validate:docs"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.5",
    "@angular/cdk": "^21.2.3",
    "@angular/common": "^21.2.5",
    "@angular/compiler": "^21.2.5",
    "@angular/core": "^21.2.5",
    "@angular/forms": "^21.2.5",
    "@angular/material": "^21.2.3",
    "@angular/platform-browser": "^21.2.5",
    "@angular/platform-browser-dynamic": "^21.2.5",
    "@angular/router": "^21.2.5",
    "dompurify": "^3.3.3",
    "fs-extra": "^11.3.4",
    "fuse.js": "^7.1.0",
    "katex": "^0.16.45",
    "markdown-it": "^14.1.1",
    "marked": "^17.0.5",
    "ngx-markdown": "^21.2.0",
    "path": "^0.12.7",
    "prismjs": "^1.30.0",
    "rxjs": "~7.8.0",
    "sass": "^1.98.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.5",
    "@types/jasmine": "^6.0.0",
    "@types/prismjs": "^1.26.6",
    "css-loader": "^7.1.4",
    "gray-matter": "^4.0.3",
    "jasmine-core": "^6.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "^2.2.0",
    "style-loader": "^4.0.0",
    "typescript": "~5.9.0",
    "xlsx": "^0.18.5"
  }
}
