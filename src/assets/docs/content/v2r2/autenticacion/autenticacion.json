      "xml": "<soapenv:Envelope xmlns:soapenv=\"http://schemas.xmlsoap.org/soap/envelope/\" xmlns:bts=\"http://uy.com.dlya.bantotal/BTSOA/\">\r\n   <soapenv:Header/>\r\n   <soapenv:Body>\r\n      <bts:Authenticate.Execute>\r\n         <bts:Btinreq>\r\n            <bts:Device>AV</bts:Device>\r\n            <bts:Usuario>MINSTALADOR</bts:Usuario>\r\n            <bts:Requerimiento></bts:Requerimiento>\r\n            <bts:Canal>BTDIGITAL</bts:Canal>\r\n            <bts:Token></bts:Token>\r\n         </bts:Btinreq>\r\n         <bts:UserId>MINSTALADOR</bts:UserId>\r\n         <bts:UserPassword>Bantotal2015</bts:UserPassword>\r\n      </bts:Authenticate.Execute>\r\n   </soapenv:Body>\r\n</soapenv:Envelope>",
